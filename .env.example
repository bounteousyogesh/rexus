# REX-US Environment Configuration
# Copy this file to .env and fill in your credentials

# Database (created by docker compose)
DATABASE_URL=postgresql://rexus:rexus_local@localhost:5434/rexus

# ServiceNow API (get from your ServiceNow admin)
SERVICENOW_INSTANCE=https://your-instance.service-now.com
SERVICENOW_CLIENT_ID=your_client_id_here
SERVICENOW_CLIENT_SECRET=your_client_secret_here

# OpenAI API (for embeddings + playbook generation)
OPENAI_API_KEY=your_openai_api_key_here

# SSO / Okta OIDC (optional — set SSO_ENABLED=true to show SSO button)
SSO_ENABLED=false
SSO_CLIENT_ID=
SSO_ISSUER_URL=
SSO_AUDIENCE=
SSO_DEFAULT_ROLE=analyst
SSO_REDIRECT_URI=http://localhost:5173/auth/callback
