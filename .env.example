# REX-US Environment Configuration
# Copy this file to .env and fill in your credentials

# Database (created by docker compose)
DATABASE_URL=postgresql://rexus:rexus_local@localhost:5434/rexus

# ServiceNow API (get from your ServiceNow admin)
SERVICENOW_INSTANCE=https://your-instance.service-now.com
SERVICENOW_CLIENT_ID=your_client_id_here
SERVICENOW_CLIENT_SECRET=your_client_secret_here

# OpenAI API (for embeddings + playbook generation)
OPENAI_API_KEY=your_openai_api_key_here

# Environment: development (local), test, staging, production
# SSO is only active when REXUS_ENV is test/staging/production AND SSO_ENABLED=true
REXUS_ENV=development

# SSO / Okta OIDC (test & production only — ignored when REXUS_ENV=development)
SSO_ENABLED=false
SSO_CLIENT_ID=
SSO_ISSUER_URL=
SSO_AUDIENCE=
SSO_DEFAULT_ROLE=analyst
SSO_REDIRECT_URI=http://localhost:5173/auth/callback

# Optional: override incident catalog CSV path (default: data/incident_catalog.csv in repo)
# CATALOG_PATH=

# Max incident numbers per POST /sync/import (default 2000)
SYNC_IMPORT_MAX_INCIDENTS=2000
