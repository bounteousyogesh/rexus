-- Migration 012: Unique constraint for incident+KB mapping (sync import dedupe).
-- Safe if 007 already applied; required if 008 recreated table without UNIQUE.

DO $$
BEGIN
    IF NOT EXISTS (
        SELECT 1 FROM pg_constraint
        WHERE conname = 'rexus_kb_article_incident_mapping_incident_number_knowledge_key'
    ) THEN
        ALTER TABLE rexus_kb_article_incident_mapping
            ADD CONSTRAINT rexus_kb_article_incident_mapping_incident_number_knowledge_key
            UNIQUE (incident_number, knowledge_article_number);
    END IF;
EXCEPTION
    WHEN duplicate_object THEN NULL;
END $$;